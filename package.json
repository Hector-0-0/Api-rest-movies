{
  "name": "movies-rest-api",
  "version": "1.0.0",
  "description": "REST API for movies built with Node.js, Express and MySQL (clean MVC architecture).",
  "main": "src/server.mjs",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.mjs",
    "dev": "node --watch src/server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "express",
    "mysql",
    "rest-api",
    "mvc",
    "nodejs"
  ],
  "author": "Hector",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.17.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  }
}
