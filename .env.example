# Server
NODE_ENV=development
PORT=3000

# CORS — lista de orígenes permitidos separados por comas (sin barra final).
# Cualquier origen *.vercel.app se permite automáticamente.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Base de datos (PostgreSQL)
# Los proveedores gestionados (Neon, Render) dan una única cadena de conexión.
# Si DATABASE_URL está definida, gana sobre las variables DB_* de abajo.
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/moviesdb?sslmode=require

DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=moviesdb
DB_PORT=5432
# Ponlo en true para proveedores que exigen TLS (Neon, Render).
# Se activa solo si DATABASE_URL contiene sslmode=require.
DB_SSL=false

# Autenticación (JWT)
# Usa una cadena larga y aleatoria en producción (p. ej. `openssl rand -hex 32`).
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_EXPIRES_IN=1d
BCRYPT_ROUNDS=10
