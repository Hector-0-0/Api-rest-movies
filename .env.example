# Server
NODE_ENV=development
PORT=3000

# CORS — comma-separated list of allowed origins (no trailing slash).
# Any *.vercel.app origin is allowed automatically.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Database (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=moviesdb
DB_PORT=3306
# Set to true for managed providers that require TLS (e.g. Aiven).
DB_SSL=false
