# Server
NODE_ENV=development
PORT=3000

# CORS — comma-separated list of allowed origins (no trailing slash).
# Any *.vercel.app origin is allowed automatically.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Database (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=moviesdb
DB_PORT=3306
# Set to true for managed providers that require TLS (e.g. Aiven).
DB_SSL=false

# Authentication (JWT)
# Use a long, random string in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_EXPIRES_IN=1d
BCRYPT_ROUNDS=10
